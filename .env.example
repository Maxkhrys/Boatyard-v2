# Buttondown — mailing list signups (https://buttondown.email/settings/api)
BUTTONDOWN_API_KEY=your-buttondown-api-key

# Sanity — journal content. Leave unset to build with placeholder posts.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Set to "false" to disable fallback posts when no Sanity content is available
PUBLIC_USE_FALLBACK_POSTS=true
