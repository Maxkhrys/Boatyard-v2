# Buttondown — mailing list signups (https://buttondown.email/settings/api)
BUTTONDOWN_API_KEY=your-buttondown-api-key

# ----- Stripe — gift voucher payments -----
# Use TEST keys (sk_test_… / whsec_…) while building; swap to the business's
# LIVE keys before launch. Switching accounts is just changing these values.
STRIPE_SECRET_KEY=sk_test_xxx
# From the webhook you create in Stripe pointing at /api/stripe-webhook
# (event: checkout.session.completed). The Stripe CLI prints one for local tests.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Resend — voucher email delivery (https://resend.com) -----
RESEND_API_KEY=re_xxx
# Sender must be on a domain verified in Resend. For first tests, the Resend
# sandbox sender below works without domain setup.
VOUCHER_FROM_EMAIL=The Boat Yard Sauna <onboarding@resend.dev>
# Business inbox BCC'd on every voucher (also used as a fallback recipient).
VOUCHER_NOTIFY_EMAIL=theboatyardsauna@gmail.com

# Sanity — journal content. Leave unset to build with placeholder posts.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# Set to "false" to disable fallback posts when no Sanity content is available
PUBLIC_USE_FALLBACK_POSTS=true
