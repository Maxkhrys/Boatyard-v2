---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { getAllPosts } from '../../lib/journal';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const isRemote = typeof post.coverImage === 'string';
---

<Base
  title={`${post.title} | The Boat Yard Sauna`}
  description={post.excerpt}
>
  <article class="note">
    <header class="note__hero">
      <div class="note__media" aria-hidden="true">
        {
          isRemote ? (
            <img src={post.coverImage as string} alt="" loading="eager" decoding="async" />
          ) : (
            <Image
              src={post.coverImage}
              alt=""
              width={1920}
              widths={[768, 1280, 1920]}
              sizes="100vw"
              format="webp"
              quality={68}
              loading="eager"
              fetchpriority="high"
            />
          )
        }
      </div>
      <div class="note__wash" aria-hidden="true"></div>
      <div class="container note__head">
        <p class="note__meta">
          <span class="note__tag">{post.tag}</span>
          <time datetime={post.isoDate}>{post.date}</time>
        </p>
        <h1 class="note__title">{post.title}</h1>
      </div>
    </header>

    <div class="container note__layout">
      <div class="note__body" set:html={post.bodyHtml} />
      <a class="link-underline note__back" href="/journal/">← Back to all notes</a>
    </div>
  </article>
</Base>

<style>
  .note__hero {
    position: relative;
    min-height: min(62vh, 34rem);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    isolation: isolate;
  }

  .note__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .note__media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .note__wash {
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      to bottom,
      rgba(11, 29, 46, 0.55) 0%,
      rgba(11, 29, 46, 0.25) 45%,
      rgba(11, 29, 46, 0.88) 100%
    );
  }

  .note__head {
    padding-block: calc(var(--nav-height) + 2rem) clamp(2.5rem, 6vw, 4rem);
  }

  .note__meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: var(--text-tiny);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  .note__tag {
    color: var(--cedar);
    font-weight: 600;
  }

  .note__title {
    margin-top: 1rem;
    font-size: clamp(2rem, 5.5vw, 4rem);
    max-width: 20ch;
  }

  .note__layout {
    padding-block: clamp(3.5rem, 8vw, 6rem) var(--space-section);
  }

  .note__body {
    max-width: 42rem;
    font-size: clamp(1.05rem, 1.3vw, 1.2rem);
    line-height: 1.75;
    color: var(--ink-soft);
  }

  .note__body :global(p + p) {
    margin-top: 1.4em;
  }

  .note__body :global(h2),
  .note__body :global(h3) {
    margin-top: 2em;
    color: var(--ink);
  }

  .note__body :global(a) {
    color: var(--cedar);
  }

  .note__body :global(img) {
    margin-block: 2em;
    border-radius: 4px;
  }

  .note__body :global(blockquote) {
    margin: 2em 0;
    padding-left: 1.5em;
    border-left: 2px solid var(--cedar);
    font-family: var(--font-display);
    font-size: 1.2em;
    color: var(--ink);
  }

  .note__back {
    display: inline-block;
    margin-top: clamp(3rem, 6vw, 4.5rem);
    padding-block: 0.75rem;
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
