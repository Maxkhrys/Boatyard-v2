---
import { Image } from 'astro:assets';
import heroImage from '../assets/images/aerial-coast-golden.jpg';

const tagline = 'Cold sea. Hot cedar. Clear head.';
---

<section class="hero" id="top">
  <div class="hero__media" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      width={2560}
      widths={[768, 1280, 1920, 2560]}
      sizes="100vw"
      format="webp"
      quality={68}
      loading="eager"
      fetchpriority="high"
    />
  </div>

  <div class="hero__wash" aria-hidden="true"></div>

  <div class="hero__mist" aria-hidden="true">
    <span class="hero__mist-layer hero__mist-layer--a"></span>
    <span class="hero__mist-layer hero__mist-layer--b"></span>
  </div>

  <div class="hero__content container">
    <p class="hero__eyebrow" data-hero-fade>
      <span class="hero__eyebrow-line" aria-hidden="true"></span>
      Wicklow Town&ensp;·&ensp;Arklow
      <span class="hero__eyebrow-line" aria-hidden="true"></span>
    </p>

    <h1 class="hero__title" data-hero-fade>
      A wood-fired sauna on the <em>harbour's edge</em>
    </h1>

    <p class="hero__tagline" data-hero-fade>{tagline}</p>

    <div class="hero__actions" data-hero-fade>
      <a href="#locations" class="btn btn--primary">Book a Session</a>
      <a href="#experience" class="link-underline hero__secondary">The Experience</a>
    </div>
  </div>

  <a class="hero__scroll" href="#intro" data-hero-fade aria-label="Scroll to explore">
    <span class="hero__scroll-line"><span></span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }

  .hero__media {
    position: absolute;
    inset: 0;
    z-index: -3;
  }

  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 50%;
    /* Slight head start so the ken-burns zoom never reveals edges */
    transform: scale(1.06);
    will-change: transform;
  }

  /* Wash: settles the photo into the navy palette and holds a soft
     vignette behind the centred copy for legibility */
  .hero__wash {
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(
        ellipse 70% 55% at 50% 52%,
        rgba(8, 21, 34, 0.42) 0%,
        transparent 75%
      ),
      linear-gradient(
        to bottom,
        rgba(11, 29, 46, 0.6) 0%,
        rgba(11, 29, 46, 0.22) 45%,
        rgba(11, 29, 46, 0.88) 100%
      );
  }

  /* Drifting sea mist */
  .hero__mist {
    position: absolute;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }

  .hero__mist-layer {
    position: absolute;
    inset: -30%;
    background: radial-gradient(
      ellipse 55% 40% at 30% 60%,
      rgba(237, 242, 240, 0.12) 0%,
      transparent 65%
    );
    filter: blur(10px);
    animation: mist-drift 34s ease-in-out infinite alternate;
  }

  .hero__mist-layer--b {
    background: radial-gradient(
      ellipse 50% 35% at 70% 45%,
      rgba(237, 242, 240, 0.08) 0%,
      transparent 60%
    );
    animation-duration: 44s;
    animation-delay: -16s;
    animation-direction: alternate-reverse;
  }

  @keyframes mist-drift {
    from {
      transform: translate3d(-6%, 2%, 0) scale(1);
    }
    to {
      transform: translate3d(6%, -3%, 0) scale(1.15);
    }
  }

  .hero__content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-block: clamp(7rem, 18vh, 10rem);
  }

  /* Eyebrow — locations held between two hairlines */
  .hero__eyebrow {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    font-size: var(--text-eyebrow);
    font-weight: 600;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--cedar);
  }

  .hero__eyebrow-line {
    display: block;
    width: clamp(2rem, 6vw, 4rem);
    height: 1px;
    background: rgba(200, 149, 108, 0.45);
  }

  .hero__title {
    margin-top: clamp(1.75rem, 4vh, 2.5rem);
    font-size: clamp(2.5rem, 6.2vw, 5.25rem);
    font-weight: 400;
    line-height: 1.08;
    letter-spacing: -0.025em;
    color: var(--mist);
    max-width: 18ch;
    text-wrap: balance;
  }

  .hero__title em {
    font-style: italic;
    font-weight: 380;
    color: var(--cedar);
  }

  .hero__tagline {
    margin-top: clamp(1.5rem, 3.5vh, 2.25rem);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    letter-spacing: 0.08em;
    color: var(--ink-soft);
  }

  .hero__actions {
    margin-top: clamp(2.25rem, 5vh, 3.25rem);
    display: flex;
    align-items: center;
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero__secondary {
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }

  html.js [data-hero-fade] {
    opacity: 0;
  }

  /* Scroll hint — a single line that breathes downward, bottom centre */
  .hero__scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--ink-soft);
    transition: color var(--dur) var(--ease);
  }

  .hero__scroll:hover {
    color: var(--cedar);
  }

  .hero__scroll-line {
    display: block;
    width: 1px;
    height: 3.25rem;
    overflow: hidden;
    background: var(--mist-10);
  }

  .hero__scroll-line span {
    display: block;
    width: 100%;
    height: 100%;
    background: linear-gradient(to bottom, transparent, currentColor);
    animation: hint-fall 2.6s var(--ease) infinite;
  }

  @keyframes hint-fall {
    from {
      transform: translateY(-100%);
    }
    to {
      transform: translateY(100%);
    }
  }

  @media (max-width: 640px) {
    .hero__content {
      padding-block: 6rem 5.5rem;
    }

    .hero__title {
      font-size: clamp(2.2rem, 9.5vw, 2.9rem);
    }

    .hero__actions {
      flex-direction: column;
      gap: 1.4rem;
      width: 100%;
    }

    .hero__actions .btn {
      width: 100%;
      max-width: 20rem;
    }

    .hero__scroll {
      bottom: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js [data-hero-fade] {
      opacity: 1;
    }

    .hero__media img {
      transform: none;
      will-change: auto;
    }

    .hero__mist-layer,
    .hero__scroll-line span {
      animation: none;
    }
  }
</style>
