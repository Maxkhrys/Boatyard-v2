---
import { Image } from 'astro:assets';
import wicklowImage from '../assets/images/aerial-wicklow-harbour.jpg';
import arklowImage from '../assets/images/sauna-gate-harbour.jpeg';

// Addresses & hours are placeholders — confirm with the real details.
const locations = [
  {
    name: 'Wicklow Town',
    blurb:
      'On the East Pier beneath the lighthouse, looking back across the harbour. Sunrise sessions are something else.',
    address: 'East Pier, Wicklow Harbour, Wicklow Town', // PLACEHOLDER
    hours: [
      { days: 'Mon – Fri', times: '7:00 — 21:00' }, // PLACEHOLDER
      { days: 'Sat – Sun', times: '8:00 — 20:00' }, // PLACEHOLDER
    ],
    mapUrl: 'https://maps.google.com/?q=The+Boat+Yard+Sauna+Wicklow',
    bookUrl:
      'https://flutterwbdev.azurewebsites.net/#/tenantDetails?tenantName=The_boat_yard_sauna',
    image: wicklowImage,
    alt: 'Aerial view of Wicklow harbour, the pier road and headland in golden evening light',
  },
  {
    name: 'Arklow',
    blurb:
      'Through the boat yard gate and straight onto the water’s edge. Moorings, masts, and steam rising off the slipway.',
    address: 'North Quay, Arklow Harbour, Arklow', // PLACEHOLDER
    hours: [
      { days: 'Mon – Fri', times: '7:00 — 21:00' }, // PLACEHOLDER
      { days: 'Sat – Sun', times: '8:00 — 20:00' }, // PLACEHOLDER
    ],
    mapUrl: 'https://maps.google.com/?q=The+Boat+Yard+Sauna+Arklow',
    bookUrl:
      'https://flutterwbdev.azurewebsites.net/#/tenantDetails?tenantName=The_Boat_Yard_Sauna_Arklow',
    image: arklowImage,
    alt: 'The Boat Yard Sauna gateway framing a harbour full of moored boats',
  },
];
---

<section class="locations section" id="locations">
  <div class="container">
    <p class="eyebrow" data-reveal>Two harbours, one ritual</p>
    <h2 class="locations__heading" data-reveal>Find us on the water’s edge.</h2>

    <div class="locations__grid">
      {
        locations.map((location) => (
          <article class="locations__card" data-reveal>
            <div class="locations__media" data-media>
              <Image
                src={location.image}
                alt={location.alt}
                width={1400}
                widths={[480, 800, 1400]}
                sizes="(min-width: 800px) 45vw, 92vw"
                format="webp"
                quality={70}
                loading="lazy"
              />
            </div>

            <div class="locations__body">
              <h3 class="locations__name">{location.name}</h3>
              <p class="locations__blurb">{location.blurb}</p>

              <dl class="locations__details">
                <div class="locations__detail">
                  <dt>Where</dt>
                  <dd>
                    {location.address}
                    <a
                      class="link-underline locations__map"
                      href={location.mapUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Open in Maps
                    </a>
                  </dd>
                </div>
                <div class="locations__detail">
                  <dt>Hours</dt>
                  <dd>
                    {location.hours.map((slot) => (
                      <span class="locations__hours-row">
                        <span>{slot.days}</span>
                        <span>{slot.times}</span>
                      </span>
                    ))}
                    <span class="locations__hours-note">Subject to tides &amp; weather</span>
                  </dd>
                </div>
              </dl>

              <a
                class="btn btn--primary locations__book"
                href={location.bookUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Book {location.name}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .locations__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
    max-width: 16ch;
  }

  .locations__grid {
    margin-top: clamp(3.5rem, 7vw, 6rem);
    display: grid;
    gap: clamp(3.5rem, 6vw, 5rem);
  }

  @media (min-width: 800px) {
    .locations__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .locations__media {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 3;
  }

  .locations__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }

  .locations__card:hover .locations__media img {
    transform: scale(1.045);
  }

  .locations__name {
    font-size: var(--text-h3);
    margin-top: 1.9rem;
  }

  .locations__blurb {
    margin-top: 0.8rem;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .locations__details {
    margin-top: 1.9rem;
    display: grid;
    gap: 1.4rem;
    padding-top: 1.9rem;
    border-top: 1px solid var(--mist-10);
  }

  .locations__detail dt {
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cedar);
  }

  .locations__detail dd {
    margin: 0.45rem 0 0;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .locations__map {
    display: inline-block;
    margin-left: 0.9em;
    font-weight: 500;
    color: var(--ink);
  }

  .locations__hours-row {
    display: flex;
    justify-content: space-between;
    max-width: 22rem;
    gap: 2rem;
  }

  .locations__hours-note {
    display: block;
    margin-top: 0.35rem;
    font-size: var(--text-tiny);
    color: var(--ink-faint);
  }

  .locations__book {
    margin-top: 2.1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .locations__card:hover .locations__media img {
      transform: none;
    }
  }
</style>
