---
import { Image } from 'astro:assets';
import { getSiteSettings, type HoursRow } from '../lib/sanity';
import wicklowImage from '../assets/images/wicklow-aerial-dusk.jpg';
import arklowImage from '../assets/images/arklow-aerial-quay.jpg';

const siteSettings = await getSiteSettings();

const wicklowDefaultHours: HoursRow[] = [
  { days: 'Mon – Thu', times: '4 – 10pm' },
  { days: 'Friday', times: '10am – 10pm' },
  { days: 'Sat – Sun', times: '8am – 10pm' },
];

const arklowDefaultHours: HoursRow[] = [
  { days: 'Mon – Wed', times: 'Closed' },
  { days: 'Thursday', times: '4 – 10pm' },
  { days: 'Friday', times: '10am – 10pm' },
  { days: 'Sat – Sun', times: '8am – 10pm' },
];

const wicklowHours: HoursRow[] =
  siteSettings?.wicklowHours && siteSettings.wicklowHours.length > 0
    ? siteSettings.wicklowHours
    : wicklowDefaultHours;

const arklowHours: HoursRow[] =
  siteSettings?.arklowHours && siteSettings.arklowHours.length > 0
    ? siteSettings.arklowHours
    : arklowDefaultHours;

const hoursNote = siteSettings?.hoursNote ?? 'Book online in advance — walk-ins subject to availability';

const locations = [
  {
    name: 'Wicklow Town',
    blurb:
      'The original benchmark for The Boatyard experience — calm, coastal, and built for proper reset time. A hot sauna, cold plunge options, tidy changing areas, warm lighting, and a peaceful coastal feel.',
    bestFor:
      'Morning resets, sea dips, recovery sessions, regular routines, small groups, and weekend wellness.',
    address: 'Wicklow Harbour, Wicklow Town',
    hours: wicklowHours,
    hoursNote,
    mapUrl: 'https://maps.google.com/?q=The+Boat+Yard+Sauna+Wicklow',
    bookUrl:
      'https://flutterwbdev.azurewebsites.net/#/tenantDetails?tenantName=The_boat_yard_sauna',
    image: wicklowImage,
    alt: 'Aerial view at dusk of The Boat Yard Sauna in Wicklow, festoon lights glowing beside the slipway and sea',
  },
  {
    name: 'Arklow',
    blurb:
      'The Boatyard experience brought to a growing local community, with the same focus on heat, cold, atmosphere, and friendly service. A warm welcome, a clean setup, hot sauna sessions, and cold plunge options throughout.',
    bestFor:
      'Local community sessions, sports recovery, group bookings, weekly routines, first-time visitors, and social sauna sessions.',
    address: 'North Quay, Arklow Harbour, Arklow',
    hours: arklowHours,
    hoursNote,
    mapUrl: 'https://maps.google.com/?q=The+Boat+Yard+Sauna+Arklow',
    bookUrl:
      'https://flutterwbdev.azurewebsites.net/#/tenantDetails?tenantName=The_Boat_Yard_Sauna_Arklow',
    image: arklowImage,
    alt: 'Aerial view of Arklow North Quay along the river, the road and quayside from above',
  },
];
---

<section class="locations section" id="locations">
  <div class="container">
    <p class="eyebrow" data-reveal>Two harbours, one ritual</p>
    <h2 class="locations__heading" data-reveal>Find us on the water's edge.</h2>

    <div class="locations__grid">
      {
        locations.map((location) => (
          <article class="locations__card" data-reveal>
            <div class="locations__media" data-media>
              <Image
                src={location.image}
                alt={location.alt}
                width={1400}
                widths={[480, 800, 1400]}
                sizes="(min-width: 800px) 45vw, 92vw"
                format="webp"
                quality={70}
                loading="lazy"
              />
            </div>

            <div class="locations__body">
              <h3 class="locations__name">{location.name}</h3>
              <p class="locations__blurb">{location.blurb}</p>

              <dl class="locations__details">
                <div class="locations__detail">
                  <dt>Where</dt>
                  <dd>
                    {location.address}
                    <a
                      class="link-underline locations__map"
                      href={location.mapUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                    >
                      Open in Maps
                    </a>
                  </dd>
                </div>
                <div class="locations__detail">
                  <dt>Hours</dt>
                  <dd>
                    {location.hours.map((slot) => (
                      <span class="locations__hours-row">
                        <span>{slot.days}</span>
                        <span>{slot.times}</span>
                      </span>
                    ))}
                    <span class="locations__hours-note">{location.hoursNote}</span>
                  </dd>
                </div>
                <div class="locations__detail">
                  <dt>Best for</dt>
                  <dd>{location.bestFor}</dd>
                </div>
              </dl>

              <a
                class="btn btn--primary locations__book"
                href={location.bookUrl}
                target="_blank"
                rel="noopener noreferrer"
              >
                Book {location.name}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .locations__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
    max-width: 16ch;
  }

  .locations__grid {
    margin-top: clamp(3.5rem, 7vw, 6rem);
    display: grid;
    gap: clamp(3.5rem, 6vw, 5rem);
  }

  @media (min-width: 800px) {
    .locations__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .locations__media {
    position: relative;
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 3;
  }

  .locations__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transition: transform 1.1s var(--ease);
  }

  .locations__card:hover .locations__media img {
    transform: scale(1.045);
  }

  .locations__name {
    font-size: var(--text-h3);
    margin-top: 1.9rem;
  }

  .locations__blurb {
    margin-top: 0.8rem;
    color: var(--ink-soft);
    max-width: 46ch;
  }

  .locations__details {
    margin-top: 1.9rem;
    display: grid;
    gap: 1.4rem;
    padding-top: 1.9rem;
    border-top: 1px solid var(--mist-10);
  }

  .locations__detail dt {
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--cedar);
  }

  .locations__detail dd {
    margin: 0.45rem 0 0;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .locations__map {
    display: inline-block;
    margin-left: 0.9em;
    font-weight: 500;
    color: var(--ink);
  }

  .locations__hours-row {
    display: flex;
    justify-content: space-between;
    max-width: 22rem;
    gap: 2rem;
  }

  .locations__hours-note {
    display: block;
    margin-top: 0.35rem;
    font-size: var(--text-tiny);
    color: var(--ink-faint);
  }

  .locations__book {
    margin-top: 2.1rem;
  }

  @media (max-width: 640px) {
    .locations__book {
      width: 100%;
    }
  }

  @media (max-width: 480px) {
    .locations__map {
      display: block;
      margin-left: 0;
      width: fit-content;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .locations__card:hover .locations__media img {
      transform: none;
    }
  }
</style>
