---
const year = new Date().getFullYear();

const locations = [
  { name: 'Wicklow Town', address: 'Wicklow Harbour, Wicklow Town' },
  { name: 'Arklow', address: 'North Quay, Arklow Harbour' },
];

const explore = [
  { label: 'About', href: '/#about' },
  { label: 'The Experience', href: '/#experience' },
  { label: 'Locations', href: '/#locations' },
  { label: 'Sessions & Pricing', href: '/#sessions' },
  { label: 'Gift Vouchers', href: '/vouchers' },
  { label: 'Good to Know', href: '/#visit' },
  { label: 'Journal', href: '/journal' },
];

const socials = [
  { name: 'Instagram', url: 'https://www.instagram.com/theboatyardsauna' },
  { name: 'Facebook', url: 'https://www.facebook.com/theboatyardsauna' },
];
---

<footer class="footer">
  <svg class="footer__wave" viewBox="0 0 1440 48" preserveAspectRatio="none" aria-hidden="true">
    <path
      d="M0 24 C 180 8, 360 40, 540 24 S 900 8, 1080 24 S 1380 40, 1440 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1"
    ></path>
  </svg>

  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__logo">
        The Boat Yard
        <span class="footer__logo-descriptor">Sauna</span>
      </p>
      <p class="footer__tag">
        A coastal sauna and cold plunge experience in Wicklow and Arklow — built around heat,
        cold, community, recovery, and atmosphere. A place to reset, reconnect, and return to.
      </p>
      <a href="mailto:theboatyardsauna@gmail.com" class="link-underline footer__email">
        theboatyardsauna@gmail.com
      </a>
      <a href="/#locations" class="btn btn--ghost footer__cta">Book a Session</a>
    </div>

    <nav class="footer__col" aria-label="Footer">
      <p class="footer__heading">Explore</p>
      <ul class="footer__list">
        {
          explore.map((link) => (
            <li>
              <a class="link-underline" href={link.href}>
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="footer__col">
      <p class="footer__heading">Find Us</p>
      <div class="footer__locations">
        {
          locations.map((location) => (
            <p class="footer__address">
              <strong>{location.name}</strong>
              {location.address}
            </p>
          ))
        }
      </div>
    </div>

    <div class="footer__col">
      <p class="footer__heading">Follow</p>
      <ul class="footer__list">
        {
          socials.map((social) => (
            <li>
              <a
                class="link-underline"
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                {social.name}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="container footer__base">
    <p>© {year} The Boat Yard Sauna</p>
    <p class="footer__credit">Made on the Irish coast</p>
    <a class="footer__top link-underline" href="#top">Back to top ↑</a>
  </div>
</footer>

<style>
  .footer {
    padding-block: clamp(3.5rem, 7vw, 5.5rem) 2.5rem;
    background: linear-gradient(to bottom, transparent, rgba(8, 21, 34, 0.65));
  }

  .footer__wave {
    display: block;
    width: 100%;
    height: 2.5rem;
    color: rgba(200, 149, 108, 0.35);
    margin-bottom: clamp(3rem, 6vw, 4.5rem);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.75rem 2rem;
  }

  .footer__brand {
    grid-column: 1 / -1;
  }

  @media (min-width: 800px) {
    .footer__inner {
      grid-template-columns: 1.6fr 1fr 1.1fr 0.8fr;
      gap: 2rem;
    }

    .footer__brand {
      grid-column: auto;
    }
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: 480;
    letter-spacing: -0.01em;
  }

  .footer__logo-descriptor {
    display: block;
    margin-top: 0.3rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--cedar);
  }

  .footer__tag {
    margin-top: 1.1rem;
    max-width: 42ch;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-mid);
  }

  .footer__email {
    display: inline-block;
    margin-top: 1.1rem;
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--ink-soft);
  }

  .footer__cta {
    margin-top: 1.75rem;
  }

  .footer__heading {
    font-size: var(--text-eyebrow);
    font-weight: 600;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--cedar);
    margin-bottom: 1.25rem;
  }

  .footer__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.35rem;
  }

  .footer__list a {
    font-size: var(--text-small);
    font-weight: 500;
    color: var(--ink-soft);
  }

  .footer__locations {
    display: grid;
    gap: 1.25rem;
    align-content: start;
  }

  .footer__address {
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .footer__address strong {
    display: block;
    font-weight: 600;
    color: var(--ink);
  }

  .footer__base {
    margin-top: clamp(3rem, 6vw, 4.5rem);
    padding-top: 1.75rem;
    border-top: 1px solid var(--mist-10);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
    font-size: var(--text-tiny);
    color: var(--ink-faint);
  }

  .footer__top {
    color: var(--ink-soft);
    font-weight: 500;
  }
</style>
