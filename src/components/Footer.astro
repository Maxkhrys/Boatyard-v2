---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <p class="footer__logo">The Boat Yard <em>Sauna</em></p>
    <p class="footer__meta">Wicklow Town · Arklow · Ireland</p>
    <p class="footer__meta">© {year} The Boat Yard Sauna</p>
  </div>
</footer>

<style>
  .footer {
    padding-block: 3.5rem;
    border-top: 1px solid rgba(237, 242, 240, 0.1);
  }

  .footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 1rem 2.5rem;
  }

  .footer__logo {
    font-family: var(--font-display);
    font-size: 1.15rem;
  }

  .footer__logo em {
    font-style: italic;
    color: var(--cedar);
  }

  .footer__meta {
    font-size: var(--text-small);
    color: var(--ink-faint);
  }

  .footer__meta:last-child {
    margin-left: auto;
  }
</style>
