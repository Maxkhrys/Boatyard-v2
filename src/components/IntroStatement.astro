---
// One sentence, three breaths. Each line fills with ink as you scroll.
const lines = [
  'Step into a hot wood-fired sauna.',
  'Cool down in the ice baths, or the sea.',
  'Take a moment to reset properly.',
];
---

<section class="statement section" id="intro">
  <div class="container">
    <p class="statement__text">
      {
        lines.map((line) => (
          <span class="statement__line">
            {line.split(' ').map((word) => (
              <span class="statement__word">{word} </span>
            ))}
          </span>
        ))
      }
    </p>
  </div>
</section>

<style>
  .statement {
    padding-block: clamp(7rem, 20vw, 16rem);
  }

  .statement__text {
    font-family: var(--font-display);
    font-size: var(--text-statement);
    font-weight: 420;
    line-height: 1.22;
    letter-spacing: -0.02em;
    max-width: 24ch;
    margin-inline: auto;
    text-wrap: balance;
  }

  .statement__line {
    display: block;
  }

  .statement__line + .statement__line {
    margin-top: 0.4em;
  }

  /* Words start as ghosts; the scrubbed timeline inks them in */
  html.js .statement__word {
    opacity: 0.14;
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .statement__word {
      opacity: 1;
    }
  }
</style>
