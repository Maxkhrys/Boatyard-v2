---
---

<header class="site-nav" id="site-nav">
  <div class="site-nav__inner">
    <a href="#top" class="site-nav__logo" aria-label="The Boat Yard Sauna — home">
      <svg class="site-nav__mark" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M11.2 3v12h1.6V3z" fill="currentColor"></path>
        <path d="M10.6 4 5 14h5.6z" fill="currentColor"></path>
        <path d="M13.4 4v9.4H19z" fill="currentColor"></path>
        <path d="M4 16.6h16l-2.2 3.8H6.2z" fill="currentColor"></path>
      </svg>
      <span class="site-nav__lockup">
        <span class="site-nav__name">The Boat Yard</span>
        <span class="site-nav__descriptor">Sauna</span>
      </span>
    </a>
    <a href="#locations" class="btn btn--primary site-nav__cta">Book</a>
  </div>
</header>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--nav-height);
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.7s var(--ease),
      border-color 0.7s var(--ease);
  }

  /* Glassy blur once the page is scrolled; tint follows the warming --bg */
  .site-nav.is-scrolled {
    background-color: color-mix(in srgb, var(--bg) 52%, transparent);
    -webkit-backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    border-bottom-color: var(--mist-10);
  }

  .site-nav__inner {
    height: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-nav__logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: var(--ink);
    transition: color var(--dur) var(--ease);
  }

  .site-nav__mark {
    width: 1.6rem;
    height: 1.6rem;
    flex-shrink: 0;
    color: var(--cedar);
    transition: transform var(--dur) var(--ease);
  }

  .site-nav__logo:hover .site-nav__mark {
    transform: translateY(-2px);
  }

  .site-nav__lockup {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-nav__name {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.4vw, 1.2rem);
    font-weight: 520;
    letter-spacing: -0.01em;
  }

  .site-nav__descriptor {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--cedar);
    transition: letter-spacing var(--dur) var(--ease);
  }

  .site-nav__logo:hover .site-nav__descriptor {
    letter-spacing: 0.5em;
  }

  .site-nav__cta {
    padding: 0.72em 1.8em;
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav__logo:hover .site-nav__mark {
      transform: none;
    }

    .site-nav__logo:hover .site-nav__descriptor {
      letter-spacing: 0.42em;
    }
  }
</style>
