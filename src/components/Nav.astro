---
// Anchor links need a leading slash everywhere except the homepage.
const onHome = Astro.url.pathname === '/';
const home = onHome ? '' : '/';

const menuLinks = [
  { label: 'About', href: `${home}#about` },
  { label: 'Sessions', href: `${home}#sessions` },
  { label: 'Good to Know', href: `${home}#visit` },
  { label: 'Vouchers', href: '/vouchers' },
  { label: 'Journal', href: '/journal' },
  { label: 'Locations', href: `${home}#locations` },
  { label: 'Book', href: `${home}#locations` },
];
---

<header class="site-nav" id="site-nav">
  <div class="site-nav__inner">
    <a href={onHome ? '#top' : '/'} class="site-nav__logo" aria-label="The Boat Yard Sauna — home">
      <svg class="site-nav__mark" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M11.2 3v12h1.6V3z" fill="currentColor"></path>
        <path d="M10.6 4 5 14h5.6z" fill="currentColor"></path>
        <path d="M13.4 4v9.4H19z" fill="currentColor"></path>
        <path d="M4 16.6h16l-2.2 3.8H6.2z" fill="currentColor"></path>
      </svg>
      <span class="site-nav__lockup">
        <span class="site-nav__name">The Boat Yard</span>
        <span class="site-nav__descriptor">Sauna</span>
      </span>
    </a>

    <a href={`${home}#locations`} class="btn btn--primary site-nav__cta">Book</a>

    <button
      class="site-nav__burger"
      id="site-nav-burger"
      type="button"
      aria-expanded="false"
      aria-controls="site-nav-menu"
      aria-label="Open menu"
    >
      <svg viewBox="0 0 24 24" width="24" height="24" aria-hidden="true">
        <line class="site-nav__burger-line site-nav__burger-line--top" x1="3" y1="6" x2="21" y2="6"></line>
        <line class="site-nav__burger-line site-nav__burger-line--mid" x1="3" y1="12" x2="21" y2="12"></line>
        <line class="site-nav__burger-line site-nav__burger-line--bot" x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>

  <nav class="site-nav__menu" id="site-nav-menu" aria-label="Site menu">
    {
      menuLinks.map((link) => (
        <a class="site-nav__menu-link" href={link.href}>
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  const nav = document.getElementById('site-nav');
  const burger = document.getElementById('site-nav-burger');
  const menu = document.getElementById('site-nav-menu');

  if (nav && burger && menu) {
    const setOpen = (open: boolean) => {
      nav.classList.toggle('is-open', open);
      burger.setAttribute('aria-expanded', String(open));
      burger.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    burger.addEventListener('click', () => {
      setOpen(!nav.classList.contains('is-open'));
    });

    // Close on link tap — navigation (or smooth scroll) takes over.
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setOpen(false));
    });

    // Close on tap outside the header.
    document.addEventListener('click', (event) => {
      if (nav.classList.contains('is-open') && !nav.contains(event.target as Node)) {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });

    // Reset if the viewport grows past the breakpoint while open.
    window.matchMedia('(min-width: 768px)').addEventListener('change', (event) => {
      if (event.matches) setOpen(false);
    });
  }
</script>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    height: var(--nav-height);
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.7s var(--ease),
      border-color 0.7s var(--ease);
  }

  /* Glassy blur once the page is scrolled; tint follows the warming --bg */
  .site-nav.is-scrolled,
  .site-nav.is-open {
    background-color: color-mix(in srgb, var(--bg) 52%, transparent);
    -webkit-backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    border-bottom-color: var(--mist-10);
  }

  .site-nav.is-open {
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
  }

  .site-nav__inner {
    height: 100%;
    max-width: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-nav__logo {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    text-decoration: none;
    color: var(--ink);
    transition: color var(--dur) var(--ease);
  }

  .site-nav__mark {
    width: 1.6rem;
    height: 1.6rem;
    flex-shrink: 0;
    color: var(--cedar);
    transition: transform var(--dur) var(--ease);
  }

  .site-nav__logo:hover .site-nav__mark {
    transform: translateY(-2px);
  }

  .site-nav__lockup {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .site-nav__name {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2.4vw, 1.2rem);
    font-weight: 520;
    letter-spacing: -0.01em;
  }

  .site-nav__descriptor {
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.42em;
    text-transform: uppercase;
    color: var(--cedar);
    transition: letter-spacing var(--dur) var(--ease);
  }

  .site-nav__logo:hover .site-nav__descriptor {
    letter-spacing: 0.5em;
  }

  .site-nav__cta {
    padding: 0.72em 1.8em;
  }

  /* ----- Burger (below 768px) ----- */

  .site-nav__burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-right: -10px; /* optically align the icon with the gutter */
    padding: 0;
    border: 0;
    border-radius: 6px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    touch-action: manipulation;
  }

  .site-nav__burger-line {
    stroke: currentColor;
    stroke-width: 1.6;
    stroke-linecap: round;
    transform-origin: 12px 12px;
    transition:
      transform var(--dur) var(--ease),
      opacity var(--dur) var(--ease);
  }

  .site-nav.is-open .site-nav__burger-line--top {
    transform: translateY(6px) rotate(45deg);
  }

  .site-nav.is-open .site-nav__burger-line--mid {
    opacity: 0;
  }

  .site-nav.is-open .site-nav__burger-line--bot {
    transform: translateY(-6px) rotate(-45deg);
  }

  /* ----- Dropdown menu (below 768px) ----- */

  .site-nav__menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    flex-direction: column;
    padding: 0.5rem var(--gutter) 1.25rem;
    background-color: color-mix(in srgb, var(--bg) 85%, transparent);
    -webkit-backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    backdrop-filter: blur(18px) saturate(1.5) brightness(1.05);
    border-bottom: 1px solid var(--mist-10);
    opacity: 0;
    transform: translateY(-0.5rem);
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      visibility 0s linear var(--dur);
  }

  .site-nav.is-open .site-nav__menu {
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    pointer-events: auto;
    transition:
      opacity var(--dur) var(--ease),
      transform var(--dur) var(--ease),
      visibility 0s;
  }

  .site-nav__menu-link {
    display: flex;
    align-items: center;
    min-height: 48px;
    padding: 0.5rem 0.25rem;
    border-bottom: 1px solid var(--mist-10);
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--ink);
    transition: color var(--dur) var(--ease);
  }

  .site-nav__menu-link:last-child {
    border-bottom: 0;
    color: var(--cedar);
  }

  .site-nav__menu-link:hover {
    color: var(--cedar);
  }

  @media (max-width: 767.98px) {
    .site-nav__cta {
      display: none;
    }

    .site-nav__burger {
      display: inline-flex;
    }

    .site-nav__menu {
      display: flex;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .site-nav__logo:hover .site-nav__mark {
      transform: none;
    }

    .site-nav__logo:hover .site-nav__descriptor {
      letter-spacing: 0.42em;
    }

    .site-nav__menu {
      transform: none;
    }
  }
</style>
