---
import { Image } from 'astro:assets';
import sunriseImage from '../assets/images/pier-lighthouse-sunrise.jpeg';
---

<section class="booking section" id="book">
  <div class="container booking__layout">
    <div class="booking__copy">
      <p class="eyebrow" data-reveal>The water is waiting</p>
      <h2 class="booking__heading" data-reveal>Step off the pier,<br />into the heat.</h2>
      <p class="booking__text" data-reveal>
        Sessions run daily from sunrise. Towels, sauna hats and a cold sea are provided —
        bring nothing but yourself.
      </p>
      <div class="booking__actions" data-reveal>
        <a href="#book" class="btn btn--primary">Book a Session</a>
        <a href="#locations" class="btn btn--ghost">Choose a Location</a>
      </div>
      <p class="booking__note" data-reveal>
        Online booking is on its way — for now, find us on the pier.
      </p>
    </div>

    <div class="booking__media" data-reveal>
      <Image
        src={sunriseImage}
        alt="A fiery red sunrise behind the pier lighthouse, sea glowing pink"
        widths={[385]}
        sizes="(min-width: 900px) 32vw, 80vw"
        format="webp"
        quality={72}
        loading="lazy"
      />
    </div>
  </div>
</section>

<style>
  .booking__layout {
    display: grid;
    gap: clamp(3rem, 7vw, 6rem);
    align-items: center;
  }

  @media (min-width: 900px) {
    .booking__layout {
      grid-template-columns: 1.2fr 0.8fr;
    }
  }

  .booking__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
  }

  .booking__text {
    margin-top: 2rem;
    max-width: 44ch;
    color: var(--ink-soft);
  }

  .booking__actions {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .booking__note {
    margin-top: 1.5rem;
    font-size: var(--text-small);
    color: var(--ink-faint);
  }

  .booking__media {
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 24px 80px rgba(224, 168, 104, 0.18);
  }

  .booking__media img {
    width: 100%;
    height: auto;
  }
</style>
