---
import JournalCard from './JournalCard.astro';
import { getAllPosts, formatDate } from '../lib/sanity';

// Homepage preview — the three most recent posts, with the full
// archive living at /journal.
const posts = (await getAllPosts()).slice(0, 3);
---

<section class="journal section" id="journal">
  <div class="container">
    <div class="journal__head">
      <div>
        <p class="eyebrow" data-reveal>Journal</p>
        <h2 class="journal__heading" data-reveal>Notes from the Harbour</h2>
      </div>
      <a class="link-underline journal__all" href="/journal" data-reveal>Read all updates →</a>
    </div>

    <div class="journal__grid">
      {
        posts.map((post) => (
          <JournalCard
            title={post.title}
            excerpt={post.excerpt}
            date={formatDate(post.publishedAt)}
            isoDate={post.publishedAt}
            tag={post.tag}
            url={`/journal/${post.slug}`}
            image={post.image}
            alt={post.alt}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .journal__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .journal__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
  }

  .journal__all {
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding-block: 0.6em;
    margin-bottom: 0.5rem;
  }

  .journal__grid {
    margin-top: clamp(3rem, 6vw, 5rem);
    display: grid;
    gap: clamp(2.5rem, 5vw, 3.5rem);
  }

  @media (min-width: 800px) {
    .journal__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
