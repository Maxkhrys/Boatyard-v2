---
const bring = ['Swimwear', 'A towel', 'Water bottle', 'Flip-flops, sliders, or sea shoes'];

const plans = [
  {
    name: 'Single Session',
    price: '€12',
    unit: 'per person',
    description:
      'One 45-minute session of heat, cold plunge, and sea air. The same standard at both harbours — Wicklow and Arklow.',
    featured: false,
  },
  {
    name: '10-Session Pack',
    price: '€110',
    unit: 'bundle · save €10',
    description:
      'Ten sessions to build sauna into your week — recovery, reset, or a regular ritual by the coast. Works at either location.',
    featured: true,
  },
  {
    name: 'Gift Voucher',
    price: 'Gift',
    unit: 'online or in person',
    description:
      'Give the gift of heat, cold, calm, and a proper reset. Buy online through Wunderbook, or pick up a physical voucher at either location.',
    featured: false,
  },
];
---

<section class="pricing section" id="sessions">
  <div class="container">
    <p class="eyebrow" data-reveal>Sessions &amp; pricing</p>
    <h2 class="pricing__heading" data-reveal>Simple as the sea.</h2>

    <div class="pricing__stage">
      {
        plans.map((plan) => (
          <article class:list={['pricing__card', plan.featured && 'pricing__card--featured']} data-reveal>
            {plan.featured && <span class="pricing__flag">Best value</span>}
            <h3 class="pricing__name">{plan.name}</h3>
            <p class="pricing__price">
              {plan.price}
              <span class="pricing__unit">{plan.unit}</span>
            </p>
            <p class="pricing__description">{plan.description}</p>
          </article>
        ))
      }
    </div>

    <div class="pricing__cta" data-reveal>
      <a class="btn btn--primary" href="/vouchers">Buy a gift voucher</a>
    </div>

    <p class="pricing__note" data-reveal>
      All sessions should be booked online in advance where possible. Walk-ins may be available
      depending on the day, but booking ahead is the best way to secure your spot.
    </p>

    <aside class="pricing__bring" data-reveal>
      <h3 class="pricing__bring-title">What to bring</h3>
      <ul class="pricing__bring-list">
        {bring.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </div>
</section>

<style>
  .pricing__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
  }

  /* Three plans, side by side from tablet up */
  .pricing__stage {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    display: grid;
    gap: clamp(1.5rem, 3vw, 2rem);
  }

  @media (min-width: 760px) {
    .pricing__stage {
      grid-template-columns: repeat(3, 1fr);
      align-items: stretch;
    }
  }

  .pricing__card {
    position: relative;
    padding: clamp(2.25rem, 4vw, 3rem) clamp(1.75rem, 3vw, 2.5rem);
    border: 1px solid var(--mist-10);
    border-radius: 6px;
    background: rgba(237, 242, 240, 0.02);
    text-align: center;
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .pricing__card--featured {
    border-color: rgba(200, 149, 108, 0.55);
    background: rgba(200, 149, 108, 0.07);
  }

  .pricing__card:hover {
    border-color: var(--cedar);
    transform: translateY(-4px);
  }

  .pricing__flag {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translate(-50%, -50%);
    padding: 0.4em 1em;
    border-radius: 999px;
    background: var(--cedar);
    color: var(--navy-deep);
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .pricing__name {
    font-size: var(--text-h3);
  }

  .pricing__price {
    margin-top: 1.4rem;
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 3.6rem);
    font-weight: 440;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pricing__unit {
    display: block;
    margin-top: 0.8rem;
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .pricing__description {
    margin-top: 1.4rem;
    max-width: 34ch;
    margin-inline: auto;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .pricing__cta {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
  }

  .pricing__note {
    margin-top: 1.75rem;
    max-width: 60ch;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-mid);
  }

  .pricing__bring {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    padding-top: 2.25rem;
    border-top: 1px solid var(--mist-10);
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 800px) {
    .pricing__bring {
      grid-template-columns: 1fr 2fr;
      align-items: baseline;
    }
  }

  .pricing__bring-title {
    font-size: var(--text-h3);
  }

  .pricing__bring-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.75rem;
  }

  .pricing__bring-list li {
    padding: 0.5em 1.1em;
    border: 1px solid var(--mist-10);
    border-radius: 999px;
    font-size: var(--text-small);
    color: var(--ink-soft);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }

  .pricing__bring-list li:hover {
    border-color: var(--cedar);
    color: var(--ink);
  }
</style>
