---
const bring = ['A towel (two is better)', 'Swimwear', 'Water — more than you think', 'Sandals for the pier'];
---

<section class="pricing section" id="sessions">
  <div class="container">
    <p class="eyebrow" data-reveal>Sessions &amp; pricing</p>
    <h2 class="pricing__heading" data-reveal>Simple as the sea.</h2>

    <div class="pricing__stage">
      <article class="pricing__card" data-reveal>
        <h3 class="pricing__name">Sauna Session</h3>
        <p class="pricing__price">
          €12
          <span class="pricing__unit">per person · open session</span>
        </p>
        <p class="pricing__description">
          Heat, plunge and the harbour view. Towels and sauna hats provided — just bring yourself
          and your swimmers.
        </p>
      </article>
    </div>

    <aside class="pricing__bring" data-reveal>
      <h3 class="pricing__bring-title">What to bring</h3>
      <ul class="pricing__bring-list">
        {bring.map((item) => <li>{item}</li>)}
      </ul>
    </aside>
  </div>
</section>

<style>
  .pricing__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
  }

  /* One option, centred, room to breathe */
  .pricing__stage {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    display: flex;
    justify-content: center;
  }

  .pricing__card {
    width: min(30rem, 100%);
    padding: clamp(2.25rem, 6vw, 3.5rem);
    border: 1px solid rgba(200, 149, 108, 0.45);
    border-radius: 6px;
    background: rgba(200, 149, 108, 0.06);
    text-align: center;
    transition:
      border-color var(--dur) var(--ease),
      transform var(--dur) var(--ease);
  }

  .pricing__card:hover {
    border-color: var(--cedar);
    transform: translateY(-4px);
  }

  .pricing__name {
    font-size: var(--text-h3);
  }

  .pricing__price {
    margin-top: 1.6rem;
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 4.5rem);
    font-weight: 440;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .pricing__unit {
    display: block;
    margin-top: 0.8rem;
    font-family: var(--font-body);
    font-size: var(--text-tiny);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .pricing__description {
    margin-top: 1.6rem;
    max-width: 34ch;
    margin-inline: auto;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .pricing__bring {
    margin-top: clamp(3.5rem, 7vw, 5.5rem);
    padding-top: 2.25rem;
    border-top: 1px solid var(--mist-10);
    display: grid;
    gap: 1.25rem;
  }

  @media (min-width: 800px) {
    .pricing__bring {
      grid-template-columns: 1fr 2fr;
      align-items: baseline;
    }
  }

  .pricing__bring-title {
    font-size: var(--text-h3);
  }

  .pricing__bring-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.75rem;
  }

  .pricing__bring-list li {
    padding: 0.5em 1.1em;
    border: 1px solid var(--mist-10);
    border-radius: 999px;
    font-size: var(--text-small);
    color: var(--ink-soft);
    transition: border-color var(--dur) var(--ease), color var(--dur) var(--ease);
  }

  .pricing__bring-list li:hover {
    border-color: var(--cedar);
    color: var(--ink);
  }
</style>
