---
import { Image } from 'astro:assets';
import seaSteps from '../assets/images/sea-steps-sunrise.jpeg';
import saunaHats from '../assets/images/sauna-hats-cedar-door.jpeg';
import oils from '../assets/images/ritual-oils-incense.jpeg';

// Placeholder content — refine copy in a later pass.
const steps = [
  {
    number: '01',
    title: 'The Plunge',
    text: 'Down the harbour steps and into the Irish Sea. Cold, bright, undeniable — the kind of wake-up no alarm can give you.',
    image: seaSteps,
    alt: 'Stone steps with handrails leading into a calm sea at sunrise',
  },
  {
    number: '02',
    title: 'The Heat',
    text: 'Into the cedar barrel. Wood-fired warmth, eucalyptus on the stove, the sea still glittering through the window.',
    image: saunaHats,
    alt: 'Grey felt sauna hats hanging on the cedar door of a barrel sauna',
  },
  {
    number: '03',
    title: 'Repeat',
    text: 'Sea to steam and back again, as many rounds as you need. You will leave lighter than you arrived.',
    image: oils,
    alt: 'Eucalyptus and lemon essential oils beside drifting incense smoke',
  },
];
---

<section class="ritual section" id="ritual">
  <div class="container">
    <p class="eyebrow" data-reveal>From the pier to the heat</p>
    <h2 class="ritual__heading" data-reveal>Cold sea. Hot cedar. Clear head.</h2>
    <p class="ritual__intro" data-reveal>
      The Boat Yard Sauna sits where the harbour meets the open water. Our ritual is as old as
      the coastline: plunge into the cold, retreat into the heat, and let the sea do the rest.
    </p>

    <ol class="ritual__steps">
      {
        steps.map((step) => (
          <li class="ritual__step" data-reveal>
            <div class="ritual__step-media">
              <Image
                src={step.image}
                alt={step.alt}
                widths={[400, 800]}
                sizes="(min-width: 768px) 30vw, 90vw"
                format="webp"
                quality={70}
                loading="lazy"
              />
            </div>
            <span class="ritual__step-number">{step.number}</span>
            <h3 class="ritual__step-title">{step.title}</h3>
            <p class="ritual__step-text">{step.text}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .ritual__heading {
    font-size: var(--text-h2);
    margin-top: 1.5rem;
    max-width: 14ch;
  }

  .ritual__intro {
    margin-top: 2rem;
    max-width: 52ch;
    color: var(--ink-soft);
  }

  .ritual__steps {
    list-style: none;
    padding: 0;
    margin-top: clamp(4rem, 8vw, 6rem);
    display: grid;
    gap: clamp(3rem, 6vw, 4rem);
  }

  @media (min-width: 768px) {
    .ritual__steps {
      grid-template-columns: repeat(3, 1fr);
    }

    .ritual__step:nth-child(2) {
      transform: translateY(clamp(2rem, 4vw, 3.5rem));
    }
  }

  .ritual__step-media {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 3 / 4;
  }

  .ritual__step-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s var(--ease-out);
  }

  .ritual__step:hover .ritual__step-media img {
    transform: scale(1.05);
  }

  .ritual__step-number {
    display: block;
    margin-top: 1.5rem;
    font-size: var(--text-small);
    font-weight: 600;
    letter-spacing: 0.2em;
    color: var(--cedar);
  }

  .ritual__step-title {
    font-size: var(--text-h3);
    margin-top: 0.5rem;
  }

  .ritual__step-text {
    margin-top: 0.75rem;
    color: var(--ink-soft);
    max-width: 36ch;
  }

  @media (prefers-reduced-motion: reduce) {
    .ritual__step:hover .ritual__step-media img {
      transform: none;
    }
  }
</style>
