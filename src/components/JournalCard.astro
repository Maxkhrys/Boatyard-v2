---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  excerpt: string;
  date: string;
  isoDate: string;
  tag: string;
  url: string;
  image: ImageMetadata | string;
  alt: string;
}

const { title, excerpt, date, isoDate, tag, url, image, alt } = Astro.props;
const isRemote = typeof image === 'string';
---

<article class="post" data-reveal>
  <a class="post__link" href={url}>
    <div class="post__media">
      {
        isRemote ? (
          <img src={image} alt={alt} loading="lazy" />
        ) : (
          <Image
            src={image}
            alt={alt}
            widths={[420, 760]}
            sizes="(min-width: 800px) 30vw, 92vw"
            format="webp"
            quality={68}
            loading="lazy"
          />
        )
      }
      <span class="post__tag-badge">{tag}</span>
    </div>
    <p class="post__meta">
      <time datetime={isoDate}>{date}</time>
    </p>
    <h3 class="post__title">{title}</h3>
    <p class="post__excerpt">{excerpt}</p>
    <span class="post__more" aria-hidden="true">
      Read note
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
        <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </a>
</article>

<style>
  .post__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post__media {
    position: relative;
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 4 / 3;
  }

  .post__media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    transition: transform 1.1s var(--ease);
  }

  .post__link:hover .post__media img {
    transform: scale(1.045);
  }

  /* Tag badge overlaid on image corner */
  .post__tag-badge {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    padding: 0.35em 0.85em;
    border-radius: 999px;
    background: rgba(11, 29, 46, 0.72);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--cedar);
    pointer-events: none;
  }

  .post__meta {
    margin-top: 1.2rem;
    font-size: var(--text-tiny);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .post__title {
    margin-top: 0.65rem;
    font-size: clamp(1.25rem, 1.9vw, 1.55rem);
    line-height: 1.18;
    transition: color var(--dur) var(--ease);
  }

  .post__link:hover .post__title {
    color: var(--cedar);
  }

  .post__excerpt {
    margin-top: 0.65rem;
    font-size: var(--text-small);
    line-height: 1.72;
    color: var(--ink-soft);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post__more {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    position: relative;
    margin-top: 1rem;
    padding-block: 0.5em;
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--cedar);
    transition: gap var(--dur) var(--ease);
  }

  .post__link:hover .post__more {
    gap: 0.8em;
  }

  @media (prefers-reduced-motion: reduce) {
    .post__link:hover .post__media img {
      transform: none;
    }
    .post__link:hover .post__more {
      gap: 0.5em;
    }
  }
</style>
