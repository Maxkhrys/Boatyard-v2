---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  excerpt: string;
  date: string;
  isoDate: string;
  tag: string;
  url: string;
  image: ImageMetadata | string;
  alt: string;
}

const { title, excerpt, date, isoDate, tag, url, image, alt } = Astro.props;
const isRemote = typeof image === 'string';
---

<article class="post" data-reveal>
  <a class="post__link" href={url}>
    <div class="post__media">
      {
        isRemote ? (
          <img src={image} alt={alt} loading="lazy" />
        ) : (
          <Image
            src={image}
            alt={alt}
            widths={[420, 760]}
            sizes="(min-width: 800px) 30vw, 92vw"
            format="webp"
            quality={68}
            loading="lazy"
          />
        )
      }
    </div>
    <p class="post__meta">
      <span class="post__tag">{tag}</span>
      <time datetime={isoDate}>{date}</time>
    </p>
    <h3 class="post__title">{title}</h3>
    <p class="post__excerpt">{excerpt}</p>
    <span class="post__more" aria-hidden="true">Read note</span>
  </a>
</article>

<style>
  .post__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .post__media {
    overflow: hidden;
    border-radius: 4px;
    aspect-ratio: 4 / 3;
  }

  .post__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.1s var(--ease);
  }

  .post__link:hover .post__media img {
    transform: scale(1.045);
  }

  .post__meta {
    margin-top: 1.4rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: var(--text-tiny);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-mid);
  }

  .post__tag {
    color: var(--cedar);
    font-weight: 600;
  }

  .post__title {
    margin-top: 0.8rem;
    font-size: clamp(1.3rem, 2vw, 1.6rem);
    transition: color var(--dur) var(--ease);
  }

  .post__link:hover .post__title {
    color: var(--cedar);
  }

  .post__excerpt {
    margin-top: 0.7rem;
    font-size: var(--text-small);
    line-height: 1.7;
    color: var(--ink-soft);
  }

  .post__more {
    display: inline-block;
    position: relative;
    margin-top: 1.1rem;
    padding-block: 0.5em;
    font-size: var(--text-tiny);
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .post__more::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0.2em;
    width: 100%;
    height: 1px;
    background: var(--cedar);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform var(--dur) var(--ease);
  }

  .post__link:hover .post__more::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  @media (prefers-reduced-motion: reduce) {
    .post__link:hover .post__media img {
      transform: none;
    }
  }
</style>
